# Copy to .env.local and fill in your DeepSeek API key.
# Get a key at https://platform.deepseek.com/

# Required.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Optional — OpenAI-compatible endpoint (default shown).
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional — default model. "deepseek-chat" tracks DeepSeek's latest
# (currently V4 Flash); "deepseek-reasoner" is the reasoning model.
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Optional — the sandbox directory the agent may read/write/run inside.
# Defaults to ./workspace (relative to the project) if unset. The agent
# cannot touch anything outside this directory.
# AGENT_WORKSPACE=/absolute/path/to/workspace
